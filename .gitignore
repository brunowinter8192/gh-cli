# Environment variables (contains secrets)
.env

# Python
__pycache__/
*.pyc
venv/

# Debug, logs, and bug fixes
debug/
**/debug/
logs/
*.log
bug_fixes/

# Dev: ignored by default; only committed investigation suites are tracked.
dev/*
!dev/repo_exploration/
!dev/content_cleaning/
!dev/tool_design/
!dev/issue_indexing/
!dev/cleanup/

# macOS
.DS_Store

# Claude Code local (not for distribution)
.claude/
.beads/

# Plugin hooks (local only)
/hooks/

# API documentation (local reference)
APIEndpoints/
endpoints.md

# Dolt database files (added by bd init)
.dolt/
*.db
